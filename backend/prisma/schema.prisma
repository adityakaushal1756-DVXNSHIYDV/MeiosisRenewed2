generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id               String          @id @default(cuid())
  meiosisId        String          @unique
  universalCode    String          @unique
  name             String
  email            String          @unique
  phone            String
  bloodGroup       String
  address          String
  healthScore      Int
  insurancePlan    String
  emergencyContact String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  abhaAddress      String?         @unique
  abhaId           String?         @unique
  shareSettings    Json?
  medicalStatus    String?         @default("normal")
  admissionWard    String?
  admissionBed     String?
  admissionTime    DateTime?
  appointments     Appointment[]
  emrShares        EmrShare[]
  labReports       LabReport[]
  messageThreads   MessageThread[]
  prescriptions    Prescription[]
  account          UserAccount?
  doctorLinks      PatientDoctor[]

  // Lifestyle & Habits
  breakfastTime    String?
  breakfastDetails String?
  lunchTime        String?
  lunchDetails     String?
  dinnerTime       String?
  dinnerDetails    String?
  snacksDetails    String?
  sleepTime        String?
  wakeupTime       String?
  teaCoffeeDetails String?
  exerciseHabits   String?
  smokingStatus    String?
  alcoholConsumption String?
  lifestyleNotes   String?
}

model Doctor {
  id                 String                   @id
  meiosisId          String                   @unique
  name               String
  specialty          String
  hospital           String
  clinicName         String?
  consultFee         Int
  rating             Float
  workingHours       String
  clinicAddress      String?
  email              String?
  phone              String?
  qualification      String?
  registrationNumber String?
  yearsExperience    Int                      @default(0)
  hfrId              String?
  hprId              String?                  @unique
  lastActiveAt       DateTime?                @default(now())
  appointments       Appointment[]
  preferences        DoctorPreferences?
  schedules          DoctorSchedule[]
  scheduleOverrides  DoctorScheduleOverride[]
  slots              AppointmentSlot[]
  emrShares          EmrShare[]
  labReports         LabReport[]
  messageThreads     MessageThread[]
  prescriptions      Prescription[]
  account            UserAccount?
  patientLinks       PatientDoctor[]
  queueSessions      QueueSession[]
  remoteCommands     RemoteCommand[]
}

model RemoteCommand {
  id        String   @id @default(cuid())
  doctorId  String
  command   String   // e.g., "OPEN_PATIENT"
  payload   Json     // e.g., { patientId: "..." }
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId, isRead])
}

/// All doctor UI/UX preferences persisted to the DB.
/// localStorage is used as a fast cache for first render;
/// DB values override localStorage after each login/load.
model DoctorPreferences {
  id                    String   @id @default(cuid())
  doctorId              String   @unique
  themeMode             String   @default("dark")
  customThemeHue        Float    @default(152)
  customThemeBrightness Float    @default(100)
  timelineTheme         String   @default("default")
  emrBuilderV2Theme     String   @default("default")
  emrBuilderLayout      String   @default("simple")
  timelineLayout        String   @default("simple")
  consoleCollapsible    Boolean  @default(false)
  consoleCollapsed      Boolean  @default(false)
  consoleWidth          Int      @default(300)
  slotDuration          Int      @default(15)
  queueBlockDuration    Int      @default(120)
  followUpGapDays       Int      @default(7)
  lang                  String   @default("en")
  prescriptionTemplates Json     @default("[]")
  pdfTemplates          Json     @default("[]")
  updatedAt             DateTime @updatedAt
  doctor                Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model UserAccount {
  id        String   @id @default(cuid())
  role      UserRole
  name      String
  email     String   @unique
  meiosisId String   @unique
  password  String
  patientId String?  @unique
  doctorId  String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  doctor    Doctor?  @relation(fields: [doctorId], references: [id])
  patient   Patient? @relation(fields: [patientId], references: [id])
}

model Appointment {
  id                String            @id @default(cuid())
  patientId         String
  doctorId          String
  title             String
  purpose           String?
  scheduledDate     DateTime
  status            AppointmentStatus
  mode              AppointmentMode
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  cancelledAt       DateTime?
  appointmentSlotId String?           @map("doctorSlotId")
  paymentMethod     String?
  paymentReference  String?
  paymentStatus     PaymentStatus     @default(PENDING)
  platformFee       Int               @default(0)
  refundAmount      Int               @default(0)
  refundStatus      RefundStatus      @default(NONE)
  doctorFee         Int               @default(0)
  paymentId         String?
  slotStartTime     DateTime?
  doctor            Doctor            @relation(fields: [doctorId], references: [id])
  appointmentSlot   AppointmentSlot?  @relation(fields: [appointmentSlotId], references: [id])
  patient           Patient           @relation(fields: [patientId], references: [id])
  payment           Payment?          @relation(fields: [paymentId], references: [id])
  queueEntry        AppointmentQueue?
}

model Payment {
  id           String        @id @default(cuid())
  patientId    String
  amount       Int
  gateway      String
  status       PaymentStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
}

model DoctorSchedule {
  id           String            @id @default(cuid())
  doctorId     String
  dayOfWeek    Int
  startTime    String
  endTime      String
  breakStart   String?
  breakEnd     String?
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  slotDuration Int               @default(30)
  doctor       Doctor            @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  slots        AppointmentSlot[]
}

model DoctorScheduleOverride {
  id           String   @id @default(cuid())
  doctorId     String
  overrideDate DateTime
  isOffDay     Boolean  @default(false)
  startTime    String?
  endTime      String?
  slotDuration Int?
  breakStart   String?
  breakEnd     String?
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  doctor       Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, overrideDate])
}

model Prescription {
  id                String             @id
  patientId         String
  doctorId          String
  title             String
  status            PrescriptionStatus
  durationDays      Int
  refillCount       Int
  adherenceScore    Int
  pharmacy          String?
  startDate         DateTime
  endDate           DateTime
  doctorNote        String
  documentPath      String?
  severity          String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  abdmCareContextId String?            @unique
  diagnosisCode     String?
  symptomCode       String?
  labReports        LabReport[]
  doctor            Doctor             @relation(fields: [doctorId], references: [id])
  patient           Patient            @relation(fields: [patientId], references: [id])
  items             PrescriptionItem[]
}

model PrescriptionItem {
  id                      String       @id @default(cuid())
  prescriptionId          String
  medicine                String
  dose                    String
  frequency               String
  timing                  String
  reason                  String
  /// Number of days this specific medicine is prescribed for.
  /// Parsed from the doctor's free-text duration field (e.g. "7 days", "2 weeks").
  /// Null for legacy records — those fall back to the parent Prescription.durationDays.
  durationDays            Int?
  dose_form               String?
  generic_name            String?
  identifier_brand        String?
  iupac_name              String?
  medicineId              String?
  molecular_formula       String?
  route_of_administration String?
  substance_identifier    String?
  therapeutic_role        String?
  prescription            Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
}

model LabReport {
  id             String        @id
  patientId      String
  doctorId       String
  testName       String
  status         LabStatus
  reportDate     DateTime
  educationalAi  String
  documentPath   String?
  prescriptionId String?
  doctor         Doctor        @relation(fields: [doctorId], references: [id])
  patient        Patient       @relation(fields: [patientId], references: [id])
  prescription   Prescription? @relation(fields: [prescriptionId], references: [id])
}

model MessageThread {
  id        String    @id @default(cuid())
  patientId String
  doctorId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
  doctor    Doctor    @relation(fields: [doctorId], references: [id])
  patient   Patient   @relation(fields: [patientId], references: [id])

  @@unique([doctorId, patientId])
}

model Message {
  id        String        @id @default(cuid())
  threadId  String
  sender    SenderRole
  text      String
  createdAt DateTime      @default(now())
  thread    MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model AppointmentSlot {
  id           String             @id @default(cuid())
  doctorId     String
  startAt      DateTime
  endAt        DateTime
  available    Boolean            @default(true)
  location     String             @default("Consultation Desk")
  mode         AppointmentMode    @default(IN_PERSON)
  scheduleId   String?
  slotDuration Int                @default(30)
  status       SlotStatus         @default(AVAILABLE)
  appointments Appointment[]
  queueEntries AppointmentQueue[]
  doctor       Doctor             @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  schedule     DoctorSchedule?    @relation(fields: [scheduleId], references: [id])

  @@map("DoctorSlot")
}

model AppointmentQueue {
  id              String          @id @default(cuid())
  appointmentId   String          @unique
  doctorSlotId    String
  appointmentTime DateTime
  queueNo         Int             @default(1)
  status          QueueStatus     @default(WAITING)
  sessionCode     String?         // Links to QueueSession for audit trail
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  appointment     Appointment     @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  appointmentSlot AppointmentSlot @relation(fields: [doctorSlotId], references: [id], onDelete: Cascade)
  session         QueueSession?   @relation(fields: [sessionCode], references: [sessionCode])

  @@index([doctorSlotId, appointmentTime])
  @@index([sessionCode])
}

/// Daily clinic queue session — one per doctor per day.
/// Acts as an audit header: links all AppointmentQueue entries for that session.
model QueueSession {
  id          String             @id @default(cuid())
  sessionCode String             @unique // Format: YYYYMMDD-HHMM-<CLINIC_CODE>
  doctorId    String
  clinicName  String             @default("Clinic")
  date        DateTime           // Midnight of the session day
  startedAt   DateTime           @default(now())
  closedAt    DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  doctor      Doctor             @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  entries     AppointmentQueue[]

  @@index([doctorId, date])
}

model EmrShare {
  id            String         @id @default(cuid())
  patientId     String
  doctorId      String
  transactionId String         @unique
  recordCount   Int
  scope         String
  createdAt     DateTime       @default(now())
  payload       Json?
  status        EmrShareStatus @default(PENDING)
  doctor        Doctor         @relation(fields: [doctorId], references: [id])
  patient       Patient        @relation(fields: [patientId], references: [id])
}

/// Persistent many-to-many doctor ↔ patient network.
/// Created when a patient adds a doctor manually OR when an appointment is booked.
/// Drives EMR access control — a doctor can only view/write EMR for patients in their network.
model PatientDoctor {
  id        String   @id @default(cuid())
  patientId String   @map("patient_id")
  doctorId  String   @map("doctor_id")
  linkedAt  DateTime @default(now()) @map("linked_at")
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([patientId, doctorId])
  @@index([patientId])
  @@index([doctorId])
  @@map("doctor_patient_links")
}

/// Compliance audit trail for every AI-Scribe transcription sent to Gemini.
/// Stores the raw original_transcript before any extraction so it can never be altered.
model AiTranscriptLog {
  id                 String   @id @default(cuid())
  originalTranscript String
  /// Nullable — may be a mock/walk-in patient not yet in the DB
  patientId          String?
  /// Nullable — manual consultations have no appointment record
  appointmentId      String?
  createdAt          DateTime @default(now())
}

enum AppointmentStatus {
  CONFIRMED
  PENDING
  COMPLETED
  CANCELLED
}

enum AppointmentMode {
  IN_PERSON
  TELECONSULT
}

enum PaymentStatus {
  PENDING
  MOCK_CONFIRMED
  REFUNDED
}

enum RefundStatus {
  NONE
  ELIGIBLE
  REFUND_INITIATED
  REFUNDED
  NOT_ELIGIBLE
}

enum QueueStatus {
  WAITING
  IN_SESSION
  PAUSED
  LATE
  NO_SHOW
  CANCELLED
  COMPLETED
}

enum SlotStatus {
  AVAILABLE
  BOOKED
  CANCELLED
}

enum PrescriptionStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

enum LabStatus {
  NORMAL
  ABNORMAL
  LOW
  PENDING
}

enum SenderRole {
  PATIENT
  DOCTOR
  SYSTEM
}

enum UserRole {
  PATIENT
  DOCTOR
}

enum EmrShareStatus {
  PENDING
  ACCEPTED
  REJECTED
}
