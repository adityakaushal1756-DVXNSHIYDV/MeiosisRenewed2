DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?schema=public"
PORT=5000

# API Keys (get from respective services)
GEMINI_API_KEY=your_gemini_api_key_here
SARVAM_API_KEY=your_sarvam_api_key_here

# CORS Configuration
# For local development on same device, leave empty (allows localhost:* automatically)
# For other devices or production, specify the frontend URL(s)
# Multiple origins: "https://app1.com,https://app2.com"
CORS_ORIGINS=

# ============================================
# DEPLOYMENT GUIDES
# ============================================
# 
# LOCAL DEVELOPMENT (backend & frontend on same machine):
#   - Leave CORS_ORIGINS empty
#   - Frontend: set VITE_API_BASE_URL=http://localhost:5000
#   - Or: use default localhost:5000 fallback
#
# OTHER DEVICE ON LOCAL NETWORK:
#   - Get backend machine IP: ipconfig (Windows) or ifconfig (Linux/Mac)
#   - Backend: set CORS_ORIGINS=http://[BACKEND_IP]:5000
#   - Frontend: set VITE_API_BASE_URL=http://[BACKEND_IP]:5000
#   - Example: CORS_ORIGINS=http://192.168.1.100:5000
#
# VERCEL DEPLOYMENT:
#   - Backend: set to your Vercel backend URL
#   - Frontend: set VITE_API_BASE_URL to your backend URL
#   - Example CORS_ORIGINS: https://api-backend-xyz.vercel.app

