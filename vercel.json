{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm run install:all",
  "buildCommand": "npm run build:frontend",
  "outputDirectory": "doctor-frontend/dist",
  "cleanUrls": true,
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "{backend/public/**,doctor-frontend/dist/**,patient-frontend/dist/**,staff-frontend/dist/**,companion-app/dist/**}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/health",
      "destination": "/api/index"
    },
    {
      "source": "/gateway",
      "destination": "/api/index"
    },
    {
      "source": "/patient-record",
      "destination": "/api/index"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/temp-access",
      "destination": "/index.html"
    }
  ]
}
